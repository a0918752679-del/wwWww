# ==============================
# 萬萬沒想到 V7 - Zeabur 環境參數
# ==============================

# Server
PORT=8080
BASE_URL=https://your-project.zeabur.app
NODE_ENV=production
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars
ADMIN_PASSWORD=69677323

# Bank Transfer
BANK_ACCOUNT=銀行：XXX銀行 / 代碼：000 / 帳號：0000-0000-0000 / 戶名：萬萬沒想到

# LINE Login
# LINE Developers > LINE Login Channel
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# LINE Messaging API（後續 LINE Bot / Rich Menu / 推播使用；本版登入不是必填）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Login
# Google Cloud Console > OAuth Client ID > Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: data file path. If unset, use ./data/db.json
DATA_FILE=
